# Copy this file to .env and fill in your values
# cp .env.example .env

# The port ShareLaTeX will be accessible on
SHARELATEX_PORT=80

# Shown in the browser tab and navigation bar
SHARELATEX_APP_NAME=My ShareLaTeX

# Full URL where the instance will be reached (important for email links etc.)
SHARELATEX_SITE_URL=http://localhost

# Admin contact email
SHARELATEX_ADMIN_EMAIL=admin@example.com

# Timezone for cron jobs (e.g. Europe/Madrid, America/New_York)
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Madrid
